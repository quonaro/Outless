{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "go",
      "args": [
        "run",
        "cmd/api/main.go"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start PostgreSQL",
      "type": "shell",
      "command": "docker-compose",
      "args": [
        "up",
        "-d",
        "--force-recreate",
        "postgres"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "close": true
      },
      "isBackground": false,
      "problemMatcher": []
    }
  ]
}