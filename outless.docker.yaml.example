database:
  url: "postgres://outless:outless@postgres:5432/outless?sslmode=disable"

api:
  shutdown_timeout: "10s"
  jwt:
    secret: "change-this-to-a-random-secret-key"
    expiry: "24h"
  admin:
    login: ""
    password: ""

checker:
  workers: 16
  latency_filter: "500ms"
  public_refresh_interval: "10m"
  # How often checker drains async probe_jobs queue (retry/check buttons).
  job_poll_interval: "5s"
  check_interval: "10m"
  # Legacy section is still supported by compatibility mapper.
  xray:
    admin_url: "http://xray-probe:10085"
    probe_url: "https://www.google.com/generate_204"
    socks_addr: "xray-probe:1080"
    geoip_db_path: ""
    geoip_db_url: ""
    geoip_auto: false
    geoip_ttl: "24h"

hub:
  # Public address advertised to clients in subscription links.
  host: "replace-with-your-public-domain"
  port: 443
  sni: "www.google.com"
  public_key: ""
  private_key: ""
  short_id: ""
  fingerprint: "chrome"
  listen_address: ":443"
  # Legacy fields are kept for compatibility.
  config_path: "/var/lib/outless/xray-hub.json"
  xray_binary: "xray"
  sync_interval: "30s"

xray:
  edge:
    # In external mode hub writes config only; xray-edge process is managed by compose.
    runtime_mode: "external"
    admin_url: "http://xray-edge:10086"
    socks_addr: "xray-edge:1081"
    config_path: "/var/lib/outless/xray-hub.json"
    # Ignored in external mode (kept for compatibility).
    xray_binary: ""
  probe:
    admin_url: "http://xray-probe:10085"
    probe_url: "https://www.google.com/generate_204"
    socks_addr: "xray-probe:1080"
    # Optional: define several probe runtimes (xray-probe, xray-probe-2, ...).
    shards:
      - admin_url: "http://xray-probe:10085"
        socks_addr: "xray-probe:1080"
      - admin_url: "http://xray-probe-2:10085"
        socks_addr: "xray-probe-2:1080"
    geoip_db_path: ""
    geoip_db_url: ""
    geoip_auto: false
    geoip_ttl: "24h"
