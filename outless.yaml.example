# Outless Configuration File
# This file is auto-generated on first run if missing

database:
  url: "postgres://outless:outless@localhost:5432/outless?sslmode=disable"

api:
  shutdown_timeout: "10s"
  jwt:
    secret: "change-this-to-a-random-secret-key"
    expiry: "24h"
  admin:
    login: ""
    password: ""

checker:
  workers: 16
  latency_filter: "500ms"
  public_refresh_interval: "10m"
  # How often checker drains async probe_jobs queue (retry/check buttons).
  job_poll_interval: "5s"
  check_interval: "10m"
  # Legacy section, kept for backward compatibility.
  # New installations should prefer top-level xray.probe below.
  xray:
    admin_url: "http://localhost:10085"
    probe_url: "https://www.google.com/generate_204"
    socks_addr: "127.0.0.1:1080"
    geoip_db_path: ""
    geoip_db_url: ""
    geoip_auto: false
    geoip_ttl: "24h"

hub:
  host: "localhost"
  port: 443
  sni: "www.google.com"
  public_key: ""
  private_key: ""
  short_id: ""
  fingerprint: "chrome"
  listen_address: ":443"
  # Legacy fields, kept for backward compatibility.
  # New installations should prefer top-level xray.edge below.
  config_path: "/var/lib/outless/xray-hub.json"
  xray_binary: "xray"
  sync_interval: "30s"

xray:
  edge:
    admin_url: "http://localhost:10086"
    socks_addr: "127.0.0.1:1081"
    config_path: "/var/lib/outless/xray-hub.json"
    xray_binary: "xray"
    runtime_mode: "embedded"
  probe:
    admin_url: "http://localhost:10085"
    probe_url: "https://www.google.com/generate_204"
    socks_addr: "127.0.0.1:1080"
    # Optional: configure multiple independent probe shards for parallel checks.
    shards:
      - admin_url: "http://localhost:10085"
        socks_addr: "127.0.0.1:1080"
    geoip_db_path: ""
    geoip_db_url: ""
    geoip_auto: false
    geoip_ttl: "24h"
